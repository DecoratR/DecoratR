{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":dependencyDashboardApproval",
        "helpers:pinGitHubActionDigests"
    ],
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0,
    "labels": [
        "dependencies"
    ],
    "nuget": {
        "ignorePaths": []
    },
    "packageRules": [
        {
            "matchDepNames": [
                "dotnet-sdk"
            ],
            "enabled": false
        },
        {
            "matchDepNames": [
                "decoratR**"
            ],
            "groupName": "DecoratR packages",
            "automerge": true
        }
    ]
}